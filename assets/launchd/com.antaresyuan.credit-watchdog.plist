<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.antaresyuan.credit-watchdog</string>
    <key>ProgramArguments</key>
    <array>
      <string>python3</string>
      <string>__INSTALL_DIR__/ccwatch.py</string>
      <string>watcher-daemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/com.antaresyuan.credit-watchdog.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/com.antaresyuan.credit-watchdog.err</string>
  </dict>
</plist>
