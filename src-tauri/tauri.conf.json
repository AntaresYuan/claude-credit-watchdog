{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Credit Watchdog",
  "version": "0.1.0",
  "identifier": "com.antaresyuan.claude-credit-watchdog",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:4174",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Credit Watchdog",
        "width": 196,
        "height": 64,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "backgroundColor": "#00000000",
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../scripts/*",
      "../assets/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
